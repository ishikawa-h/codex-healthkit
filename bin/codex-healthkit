#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0-alpha.1"
FORMAT="markdown"
WITH_CODEX_VERSION=0
WITH_CODEX_DOCTOR=0
WITH_RUNTIME=0
COMPARE_FILE=""
COMPARE_REQUESTED=0
COMPARE_LOADED=0
COMPARE_NOTE="not requested; pass --compare <previous-report.json> to compare metadata deltas"
COMMAND="check"

usage() {
  cat <<'USAGE'
codex-healthkit - local metadata health checks for daily Codex operators

Usage:
  codex-healthkit check [--markdown|--json] [--compare <previous-report.json>] [--with-codex-version] [--with-codex-doctor] [--with-runtime]
  codex-healthkit --version
  codex-healthkit --help

Default behavior:
  Performs local file metadata checks only. It does not read auth files,
  SQLite contents, session transcript contents, token files, or cookies, and
  it does not execute the external codex command.

Optional:
  --compare <previous-report.json> compares current metadata with an explicit
     previous codex-healthkit JSON report. Requires jq. Does not store history.
  --with-codex-version runs `codex --version`.
  --with-codex-doctor runs official `codex doctor --json` and extracts only
     redacted summary fields (status, ok/warn/fail counts, and a note). Raw
     doctor output is not included. Codex CLI may perform provider reachability
     checks through the existing Codex configuration when this option is enabled.
  --with-runtime collects macOS memory pressure, swap usage, and bounded process
     metadata (PID, PPID, RSS, uptime, and normalized process category). It does
     not read command arguments, environment variables, or open files. Other
     operating systems report runtime diagnostics as unsupported.
USAGE
}

die() {
  printf 'codex-healthkit: %s\n' "$*" >&2
  exit 2
}

safe_text() {
  LC_ALL=C tr '\001-\037\177' ' '
}

json_string() {
  local text
  text="$(printf '%s' "$1" | safe_text)"
  text="${text//\\/\\\\}"
  text="${text//\"/\\\"}"
  printf '"%s"' "$text"
}

markdown_inline() {
  local text
  text="$(printf '%s' "$1" | safe_text)"
  text="${text//\\/\\\\}"
  text="${text//|/\\|}"
  text="${text//\`/\\\`}"
  printf '%s' "$text"
}

bool_json() {
  if [ "$1" = "1" ]; then
    printf 'true'
  else
    printf 'false'
  fi
}

bytes_for() {
  local path="$1"
  if [ ! -e "$path" ] || [ -L "$path" ]; then
    printf '0'
    return
  fi

  if stat -f '%z' "$path" >/dev/null 2>&1; then
    stat -f '%z' "$path" 2>/dev/null || printf '0'
    return
  fi

  if stat -c '%s' "$path" >/dev/null 2>&1; then
    stat -c '%s' "$path" 2>/dev/null || printf '0'
    return
  fi

  printf '0'
}

tree_bytes_for() {
  local path="$1"
  if [ ! -e "$path" ] || [ -L "$path" ]; then
    printf '0'
    return
  fi

  if [ -d "$path" ]; then
    du -sk "$path" 2>/dev/null | awk '{printf "%d", $1 * 1024}' || printf '0'
    return
  fi

  bytes_for "$path"
}

human_size_for() {
  local path="$1"
  if [ ! -e "$path" ] || [ -L "$path" ]; then
    printf '0B'
    return
  fi

  du -sh "$path" 2>/dev/null | awk '{print $1}' || printf '0B'
}

count_jsonl_files() {
  local path="$1"
  if [ ! -d "$path" ] || [ -L "$path" ]; then
    printf '0'
    return
  fi

  { find "$path" -type f -name '*.jsonl' -print 2>/dev/null || true; } | wc -l | tr -d '[:space:]'
}

path_exists_bool() {
  local path="$1"
  if [ -e "$path" ] && [ ! -L "$path" ]; then
    printf '1'
  else
    printf '0'
  fi
}

resolve_sqlite_home() {
  local raw="${CODEX_SQLITE_HOME:-${CODEX_HOME:-$HOME/.codex}}"
  case "$raw" in
    /*) printf '%s' "$raw" ;;
    *) printf '%s/%s' "$PWD" "$raw" ;;
  esac
}

health_note() {
  local db_bytes="$1"
  local wal_bytes="$2"
  local gib=$((1024 * 1024 * 1024))
  local mib=$((1024 * 1024))

  if [ "$db_bytes" -ge $((2 * gib)) ] || [ "$wal_bytes" -ge $((500 * mib)) ]; then
    printf 'watch: log DB or WAL is large; compare with a previous check.'
  elif [ "$wal_bytes" -ge $((100 * mib)) ]; then
    printf 'watch: WAL is above 100MB; check again after normal use.'
  else
    printf 'ok: no large WAL spike detected by size-only check.'
  fi
}

overall_status_for() {
  local db_bytes="$1"
  local wal_bytes="$2"
  local gib=$((1024 * 1024 * 1024))
  local mib=$((1024 * 1024))

  if [ "$db_bytes" -ge $((2 * gib)) ] || [ "$wal_bytes" -ge $((100 * mib)) ]; then
    printf 'watch'
  else
    printf 'ok'
  fi
}

human_bytes_value() {
  local bytes="$1"
  local abs="$bytes"

  if [ "$abs" -lt 0 ]; then
    abs=$((-abs))
  fi

  if [ "$abs" -ge 1073741824 ]; then
    awk -v bytes="$abs" 'BEGIN { printf "%.1fG", bytes / 1073741824 }'
  elif [ "$abs" -ge 1048576 ]; then
    awk -v bytes="$abs" 'BEGIN { printf "%.1fM", bytes / 1048576 }'
  elif [ "$abs" -ge 1024 ]; then
    awk -v bytes="$abs" 'BEGIN { printf "%.1fK", bytes / 1024 }'
  else
    printf '%dB' "$abs"
  fi
}

signed_human_delta_bytes() {
  local delta="$1"
  if [ "$delta" -gt 0 ]; then
    printf '+%s' "$(human_bytes_value "$delta")"
  elif [ "$delta" -lt 0 ]; then
    printf -- '-%s' "$(human_bytes_value "$delta")"
  else
    printf '0B'
  fi
}

signed_delta_count() {
  local delta="$1"
  if [ "$delta" -gt 0 ]; then
    printf '+%d' "$delta"
  else
    printf '%d' "$delta"
  fi
}

direction_for_delta() {
  local delta="$1"
  if [ "$delta" -gt 0 ]; then
    printf 'increased'
  elif [ "$delta" -lt 0 ]; then
    printf 'decreased'
  else
    printf 'unchanged'
  fi
}

elapsed_seconds() {
  local value="$1" days=0 hours=0 minutes=0 seconds=0 rest
  case "$value" in
    *-*)
      days="${value%%-*}"
      rest="${value#*-}"
      ;;
    *) rest="$value" ;;
  esac

  case "$rest" in
    *:*:*)
      hours="${rest%%:*}"
      rest="${rest#*:}"
      minutes="${rest%%:*}"
      seconds="${rest##*:}"
      ;;
    *:*)
      minutes="${rest%%:*}"
      seconds="${rest##*:}"
      ;;
    *) return 1 ;;
  esac

  case "$days:$hours:$minutes:$seconds" in
    *[!0-9:]*) return 1 ;;
  esac
  printf '%d' "$((10#$days * 86400 + 10#$hours * 3600 + 10#$minutes * 60 + 10#$seconds))"
}

runtime_category() {
  local executable="${1##*/}"
  case "$executable" in
    *Codex*Renderer*) printf 'codex_renderer' ;;
    SkyComputerUseClient) printf 'computer_use_client' ;;
    SkyComputerUseService) printf 'computer_use_service' ;;
    playwright-mcp|playwright-mcp-*) printf 'playwright_worker' ;;
    *) return 1 ;;
  esac
}

runtime_status_for_pressure() {
  local swap_mib="$1" free_percent="$2"
  if [ "$swap_mib" -ge 8192 ] || { [ "$free_percent" -ge 0 ] && [ "$free_percent" -le 10 ]; }; then
    printf 'watch'
  elif [ "$swap_mib" -ge 4096 ] || { [ "$free_percent" -ge 0 ] && [ "$free_percent" -le 20 ]; }; then
    printf 'observe'
  else
    printf 'ok'
  fi
}

parse_swap_mib() {
  awk '
    {
      for (i = 1; i <= NF; i++) {
        if ($i == "used" && $(i + 1) == "=") {
          value = $(i + 2)
          unit = substr(value, length(value), 1)
          sub(/[MGT]$/, "", value)
          if (unit == "G") value *= 1024
          if (unit == "T") value *= 1048576
          printf "%d", value + 0
          exit
        }
      }
    }
  '
}

process_group_json() {
  local category="$1" first=1 parent_state
  printf '{"count":%s,"rss_bytes":%s,"orphan_candidate_count":%s,"ppid_init_candidate_count":%s,"parent_missing_candidate_count":%s,"long_running_count":%s,"residual_candidate_count":%s,"items":[' \
    "$(runtime_group_value "$category" 2)" \
    "$(( $(runtime_group_value "$category" 3) * 1024 ))" \
    "$(runtime_group_value "$category" 4)" \
    "$(runtime_group_value "$category" 6)" \
    "$(runtime_group_value "$category" 7)" \
    "$(runtime_group_value "$category" 5)" \
    "$(runtime_group_value "$category" 8)"
  while IFS='|' read -r row_category pid ppid rss_kb uptime started parent_present orphan long_running ppid_init parent_missing residual; do
    [ "$row_category" = "$category" ] || continue
    if [ "$first" -eq 0 ]; then printf ','; fi
    first=0
    if [ "$ppid_init" -eq 1 ]; then parent_state="init"; elif [ "$parent_missing" -eq 1 ]; then parent_state="missing"; else parent_state="present"; fi
    printf '{"pid":%s,"ppid":%s,"rss_bytes":%s,"uptime_seconds":%s,"started_at_epoch":%s,"parent_present":%s,"parent_state":%s,"orphan_candidate":%s,"long_running":%s,"residual_candidate":%s}' \
      "$pid" "$ppid" "$((rss_kb * 1024))" "$uptime" "$started" \
      "$(bool_json "$parent_present")" "$(json_string "$parent_state")" "$(bool_json "$orphan")" "$(bool_json "$long_running")" "$(bool_json "$residual")"
  done <"$RUNTIME_TARGETS_FILE"
  printf ']}'
}

runtime_group_value() {
  local category="$1" field="$2"
  awk -F '|' -v category="$category" -v field="$field" '
    $1 == category {
      count++
      rss += $4
      orphan += $8
      long_running += $9
      ppid_init += $10
      parent_missing += $11
      residual += $12
    }
    END {
      if (field == 2) print count + 0
      else if (field == 3) print rss + 0
      else if (field == 4) print orphan + 0
      else if (field == 5) print long_running + 0
      else if (field == 6) print ppid_init + 0
      else if (field == 7) print parent_missing + 0
      else if (field == 8) print residual + 0
    }
  ' "$RUNTIME_TARGETS_FILE"
}

collect_runtime() {
  local os_name ps_source pressure_source swap_source now_epoch
  RUNTIME_REQUESTED="$WITH_RUNTIME"
  RUNTIME_SUPPORTED=0
  RUNTIME_STATUS="skipped"
  RUNTIME_NOTE="not requested; pass --with-runtime for bounded macOS runtime metadata"
  RUNTIME_MEMORY_FREE_PERCENT=-1
  RUNTIME_SWAP_USED_MIB=0
  : >"$RUNTIME_TARGETS_FILE"

  [ "$WITH_RUNTIME" -eq 1 ] || return 0
  os_name="${CODEX_HEALTHKIT_TEST_OS:-$(uname -s 2>/dev/null || printf 'unknown')}"
  RUNTIME_OS="$os_name"
  if [ "$os_name" != "Darwin" ]; then
    RUNTIME_STATUS="unsupported"
    RUNTIME_NOTE="runtime diagnostics are currently supported on macOS only; existing checks continued"
    return
  fi

  RUNTIME_SUPPORTED=1
  RUNTIME_STATUS="ok"
  RUNTIME_NOTE="bounded macOS runtime metadata collected; process arguments, environment variables, and open files were not read"

  if [ -n "${CODEX_HEALTHKIT_TEST_RUNTIME_DIR:-}" ]; then
    pressure_source="$CODEX_HEALTHKIT_TEST_RUNTIME_DIR/memory_pressure.txt"
    swap_source="$CODEX_HEALTHKIT_TEST_RUNTIME_DIR/swapusage.txt"
    ps_source="$CODEX_HEALTHKIT_TEST_RUNTIME_DIR/ps.txt"
  else
    pressure_source="$RUNTIME_PRESSURE_FILE"
    swap_source="$RUNTIME_SWAP_FILE"
    ps_source="$RUNTIME_PS_FILE"
    memory_pressure -Q >"$pressure_source" 2>/dev/null || true
    sysctl -n vm.swapusage >"$swap_source" 2>/dev/null || true
    ps -axo pid=,ppid=,rss=,etime=,comm= >"$ps_source" 2>/dev/null || true
  fi

  RUNTIME_MEMORY_FREE_PERCENT="$(awk '/System-wide memory free percentage:/ {gsub(/%/, "", $NF); print $NF; exit}' "$pressure_source" 2>/dev/null || true)"
  case "$RUNTIME_MEMORY_FREE_PERCENT" in ''|*[!0-9]*) RUNTIME_MEMORY_FREE_PERCENT=-1 ;; esac
  RUNTIME_SWAP_USED_MIB="$(parse_swap_mib <"$swap_source" 2>/dev/null || true)"
  case "$RUNTIME_SWAP_USED_MIB" in ''|*[!0-9]*) RUNTIME_SWAP_USED_MIB=0 ;; esac

  now_epoch="${CODEX_HEALTHKIT_TEST_EPOCH:-$(date +%s)}"
  awk '{print $1}' "$ps_source" 2>/dev/null >"$RUNTIME_PIDS_FILE" || true
  while read -r pid ppid rss_kb elapsed executable; do
    local category uptime started parent_present=0 orphan=0 long_running=0 ppid_init=0 parent_missing=0 residual=0
    case "$pid:$ppid:$rss_kb" in *[!0-9:]*) continue ;; esac
    category="$(runtime_category "$executable" 2>/dev/null || true)"
    [ -n "$category" ] || continue
    uptime="$(elapsed_seconds "$elapsed" 2>/dev/null || true)"
    case "$uptime" in ''|*[!0-9]*) continue ;; esac
    started=$(( (now_epoch - uptime) / 60 * 60 ))
    if grep -qx "$ppid" "$RUNTIME_PIDS_FILE" 2>/dev/null; then parent_present=1; fi
    if [ "$ppid" -le 1 ]; then ppid_init=1; orphan=1
    elif [ "$parent_present" -eq 0 ]; then parent_missing=1; orphan=1
    fi
    if [ "$uptime" -ge 21600 ]; then long_running=1; fi
    if [ "$orphan" -eq 1 ] && [ "$long_running" -eq 1 ]; then residual=1; fi
    printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
      "$category" "$pid" "$ppid" "$rss_kb" "$uptime" "$started" "$parent_present" "$orphan" "$long_running" "$ppid_init" "$parent_missing" "$residual" \
      >>"$RUNTIME_TARGETS_FILE"
  done <"$ps_source"

  if [ ! -s "$pressure_source" ] && [ ! -s "$swap_source" ]; then
    RUNTIME_STATUS="unavailable"
    RUNTIME_NOTE="macOS runtime commands returned no memory or swap metadata; existing checks continued"
  else
    RUNTIME_STATUS="$(runtime_status_for_pressure "$RUNTIME_SWAP_USED_MIB" "$RUNTIME_MEMORY_FREE_PERCENT")"
  fi
}

runtime_json() {
  cat <<JSON
{
    "requested": $(bool_json "$RUNTIME_REQUESTED"),
    "supported": $(bool_json "$RUNTIME_SUPPORTED"),
    "os": $(json_string "$RUNTIME_OS"),
    "status": $(json_string "$RUNTIME_STATUS"),
    "note": $(json_string "$RUNTIME_NOTE"),
    "memory": {
      "free_percent": $RUNTIME_MEMORY_FREE_PERCENT,
      "swap_used_mib": $RUNTIME_SWAP_USED_MIB,
      "pressure_status": $(json_string "$RUNTIME_STATUS")
    },
    "processes": {
      "codex_renderer": $(process_group_json codex_renderer),
      "computer_use_client": $(process_group_json computer_use_client),
      "computer_use_service": $(process_group_json computer_use_service),
      "playwright_worker": $(process_group_json playwright_worker)
    },
    "thresholds": {
      "swap_observe_mib": 4096,
      "swap_watch_mib": 8192,
      "memory_free_observe_percent": 20,
      "memory_free_watch_percent": 10,
      "long_running_seconds": 21600,
      "renderer_churn_events": 4,
      "worker_growth_count": 10
    }
  }
JSON
}

previous_number() {
  local filter="$1"
  jq -er "$filter // 0 | if type == \"number\" then . else 0 end" "$COMPARE_FILE" 2>/dev/null || printf '0'
}

previous_string() {
  local filter="$1"
  jq -r "$filter // \"\"" "$COMPARE_FILE" 2>/dev/null || printf ''
}

comparison_json() {
  if [ "$COMPARE_REQUESTED" -ne 1 ]; then
    cat <<JSON
{
    "requested": false,
    "loaded": false,
    "note": $(json_string "$COMPARE_NOTE")
  }
JSON
    return
  fi

  cat <<JSON
{
    "requested": true,
    "loaded": $(bool_json "$COMPARE_LOADED"),
    "previous_generated_at": $(json_string "$PREVIOUS_GENERATED_AT"),
    "note": $(json_string "$COMPARE_NOTE"),
    "items": {
      "logs_2_sqlite_wal": {
        "previous_bytes": $PREV_LOG_WAL_BYTES,
        "current_bytes": $LOG_WAL_BYTES,
        "delta_bytes": $DELTA_LOG_WAL_BYTES,
        "direction": $(json_string "$(direction_for_delta "$DELTA_LOG_WAL_BYTES")")
      },
      "logs_2_sqlite": {
        "previous_bytes": $PREV_LOG_DB_BYTES,
        "current_bytes": $LOG_DB_BYTES,
        "delta_bytes": $DELTA_LOG_DB_BYTES,
        "direction": $(json_string "$(direction_for_delta "$DELTA_LOG_DB_BYTES")")
      },
      "sessions_bytes": {
        "previous_bytes": $PREV_SESSIONS_BYTES,
        "current_bytes": $SESSIONS_BYTES,
        "delta_bytes": $DELTA_SESSIONS_BYTES,
        "direction": $(json_string "$(direction_for_delta "$DELTA_SESSIONS_BYTES")")
      },
      "sessions_jsonl_count": {
        "previous_count": $PREV_SESSIONS_COUNT,
        "current_count": $SESSIONS_COUNT,
        "delta_count": $DELTA_SESSIONS_COUNT,
        "direction": $(json_string "$(direction_for_delta "$DELTA_SESSIONS_COUNT")")
      },
      "archived_sessions_bytes": {
        "previous_bytes": $PREV_ARCHIVED_BYTES,
        "current_bytes": $ARCHIVED_BYTES,
        "delta_bytes": $DELTA_ARCHIVED_BYTES,
        "direction": $(json_string "$(direction_for_delta "$DELTA_ARCHIVED_BYTES")")
      },
      "archived_sessions_jsonl_count": {
        "previous_count": $PREV_ARCHIVED_COUNT,
        "current_count": $ARCHIVED_COUNT,
        "delta_count": $DELTA_ARCHIVED_COUNT,
        "direction": $(json_string "$(direction_for_delta "$DELTA_ARCHIVED_COUNT")")
      },
      "quarantine_bytes": {
        "previous_bytes": $PREV_QUARANTINE_BYTES,
        "current_bytes": $QUARANTINE_BYTES,
        "delta_bytes": $DELTA_QUARANTINE_BYTES,
        "direction": $(json_string "$(direction_for_delta "$DELTA_QUARANTINE_BYTES")")
      },
      "runtime": {
        "available": $(bool_json "$RUNTIME_COMPARE_AVAILABLE"),
        "note": $(json_string "$RUNTIME_COMPARE_NOTE"),
        "codex_renderer": {
          "started_count": $RUNTIME_RENDERER_STARTED,
          "exited_count": $RUNTIME_RENDERER_EXITED,
          "churn_candidate": $(bool_json "$RUNTIME_RENDERER_CHURN")
        },
        "computer_use_client_count": {
          "previous_count": $PREV_COMPUTER_USE_CLIENT_COUNT,
          "current_count": $CURRENT_COMPUTER_USE_CLIENT_COUNT,
          "delta_count": $DELTA_COMPUTER_USE_CLIENT_COUNT,
          "growth_candidate": $(bool_json "$COMPUTER_USE_CLIENT_GROWTH")
        },
        "playwright_worker_count": {
          "previous_count": $PREV_PLAYWRIGHT_WORKER_COUNT,
          "current_count": $CURRENT_PLAYWRIGHT_WORKER_COUNT,
          "delta_count": $DELTA_PLAYWRIGHT_WORKER_COUNT,
          "growth_candidate": $(bool_json "$PLAYWRIGHT_WORKER_GROWTH")
        }
      }
    }
  }
JSON
}

load_runtime_comparison() {
  local previous_supported current_supported events
  RUNTIME_COMPARE_AVAILABLE=0
  RUNTIME_COMPARE_NOTE="runtime comparison unavailable; collect both reports with --with-runtime on macOS"
  previous_supported="$(jq -r '.runtime.supported // false' "$COMPARE_FILE" 2>/dev/null || printf 'false')"
  current_supported="$(bool_json "$RUNTIME_SUPPORTED")"
  if [ "$previous_supported" != "true" ] || [ "$current_supported" != "true" ]; then
    return 0
  fi

  jq -r '.runtime.processes.codex_renderer.items[]? | "\(.pid):\(.started_at_epoch)"' "$COMPARE_FILE" 2>/dev/null | sort -u >"$RUNTIME_PREVIOUS_IDS_FILE"
  awk -F '|' '$1 == "codex_renderer" {print $2 ":" $6}' "$RUNTIME_TARGETS_FILE" | sort -u >"$RUNTIME_CURRENT_IDS_FILE"
  RUNTIME_RENDERER_STARTED="$(comm -13 "$RUNTIME_PREVIOUS_IDS_FILE" "$RUNTIME_CURRENT_IDS_FILE" | wc -l | tr -d '[:space:]')"
  RUNTIME_RENDERER_EXITED="$(comm -23 "$RUNTIME_PREVIOUS_IDS_FILE" "$RUNTIME_CURRENT_IDS_FILE" | wc -l | tr -d '[:space:]')"
  events=$((RUNTIME_RENDERER_STARTED + RUNTIME_RENDERER_EXITED))
  if [ "$events" -ge 4 ]; then RUNTIME_RENDERER_CHURN=1; fi

  PREV_COMPUTER_USE_CLIENT_COUNT="$(previous_number '.runtime.processes.computer_use_client.count')"
  PREV_PLAYWRIGHT_WORKER_COUNT="$(previous_number '.runtime.processes.playwright_worker.count')"
  CURRENT_COMPUTER_USE_CLIENT_COUNT="$(runtime_group_value computer_use_client 2)"
  CURRENT_PLAYWRIGHT_WORKER_COUNT="$(runtime_group_value playwright_worker 2)"
  DELTA_COMPUTER_USE_CLIENT_COUNT=$((CURRENT_COMPUTER_USE_CLIENT_COUNT - PREV_COMPUTER_USE_CLIENT_COUNT))
  DELTA_PLAYWRIGHT_WORKER_COUNT=$((CURRENT_PLAYWRIGHT_WORKER_COUNT - PREV_PLAYWRIGHT_WORKER_COUNT))
  if [ "$DELTA_COMPUTER_USE_CLIENT_COUNT" -ge 10 ]; then COMPUTER_USE_CLIENT_GROWTH=1; fi
  if [ "$DELTA_PLAYWRIGHT_WORKER_COUNT" -ge 10 ]; then PLAYWRIGHT_WORKER_GROWTH=1; fi
  RUNTIME_COMPARE_AVAILABLE=1
  RUNTIME_COMPARE_NOTE="PID and estimated start-time metadata compared; churn and worker growth are candidates for review, not proof of a leak or orphan"
}

comparison_markdown() {
  if [ "$COMPARE_REQUESTED" -ne 1 ]; then
    return
  fi

  cat <<MARKDOWN

## Previous Report Comparison

- requested: \`yes\`
- previous_generated_at: \`$(markdown_inline "$PREVIOUS_GENERATED_AT")\`
- note: $(markdown_inline "$COMPARE_NOTE")

| item | previous | current | delta | note |
|---|---:|---:|---:|---|
| logs_2.sqlite-wal | $(human_bytes_value "$PREV_LOG_WAL_BYTES") | $(human_bytes_value "$LOG_WAL_BYTES") | $(signed_human_delta_bytes "$DELTA_LOG_WAL_BYTES") | size only; SQLite contents not read |
| logs_2.sqlite | $(human_bytes_value "$PREV_LOG_DB_BYTES") | $(human_bytes_value "$LOG_DB_BYTES") | $(signed_human_delta_bytes "$DELTA_LOG_DB_BYTES") | size only; SQLite contents not read |
| active sessions | $(human_bytes_value "$PREV_SESSIONS_BYTES") / $PREV_SESSIONS_COUNT | $(human_bytes_value "$SESSIONS_BYTES") / $SESSIONS_COUNT | $(signed_human_delta_bytes "$DELTA_SESSIONS_BYTES") / $(signed_delta_count "$DELTA_SESSIONS_COUNT") | file count only; transcript contents not read |
| archived sessions | $(human_bytes_value "$PREV_ARCHIVED_BYTES") / $PREV_ARCHIVED_COUNT | $(human_bytes_value "$ARCHIVED_BYTES") / $ARCHIVED_COUNT | $(signed_human_delta_bytes "$DELTA_ARCHIVED_BYTES") / $(signed_delta_count "$DELTA_ARCHIVED_COUNT") | normal growth can be expected; review before deleting |
| quarantine | $(human_bytes_value "$PREV_QUARANTINE_BYTES") | $(human_bytes_value "$QUARANTINE_BYTES") | $(signed_human_delta_bytes "$DELTA_QUARANTINE_BYTES") | metadata only |
MARKDOWN

  if [ "$RUNTIME_COMPARE_AVAILABLE" -eq 1 ]; then
    cat <<MARKDOWN

### Runtime Comparison

- renderer started/exited candidates: \`$RUNTIME_RENDERER_STARTED / $RUNTIME_RENDERER_EXITED\`
- renderer churn candidate: \`$(if [ "$RUNTIME_RENDERER_CHURN" -eq 1 ]; then printf 'yes'; else printf 'no'; fi)\`
- computer-use client count delta: \`$(signed_delta_count "$DELTA_COMPUTER_USE_CLIENT_COUNT")\`
- computer-use client growth candidate: \`$(if [ "$COMPUTER_USE_CLIENT_GROWTH" -eq 1 ]; then printf 'yes'; else printf 'no'; fi)\`
- playwright worker count delta: \`$(signed_delta_count "$DELTA_PLAYWRIGHT_WORKER_COUNT")\`
- playwright worker growth candidate: \`$(if [ "$PLAYWRIGHT_WORKER_GROWTH" -eq 1 ]; then printf 'yes'; else printf 'no'; fi)\`
- note: $(markdown_inline "$RUNTIME_COMPARE_NOTE")
MARKDOWN
  fi
}

runtime_markdown() {
  local category label count rss long_running
  cat <<MARKDOWN

## Optional macOS Runtime Metadata

- requested: \`$(if [ "$RUNTIME_REQUESTED" -eq 1 ]; then printf 'yes'; else printf 'no'; fi)\`
- supported: \`$(if [ "$RUNTIME_SUPPORTED" -eq 1 ]; then printf 'yes'; else printf 'no'; fi)\`
- os: \`$(markdown_inline "$RUNTIME_OS")\`
- status: \`$(markdown_inline "$RUNTIME_STATUS")\`
- memory free: \`$(if [ "$RUNTIME_MEMORY_FREE_PERCENT" -ge 0 ]; then printf '%s%%' "$RUNTIME_MEMORY_FREE_PERCENT"; else printf 'unavailable'; fi)\`
- swap used: \`${RUNTIME_SWAP_USED_MIB} MiB\`
- note: $(markdown_inline "$RUNTIME_NOTE")

| process category | count | RSS | PPID 0/1 | parent missing | long-running | residual candidate |
|---|---:|---:|---:|---:|---:|---:|
MARKDOWN
  for category in codex_renderer computer_use_client computer_use_service playwright_worker; do
    case "$category" in
      codex_renderer) label="Codex Renderer" ;;
      computer_use_client) label="Computer Use client" ;;
      computer_use_service) label="Computer Use service" ;;
      playwright_worker) label="Playwright worker" ;;
    esac
    count="$(runtime_group_value "$category" 2)"
    rss=$(( $(runtime_group_value "$category" 3) * 1024 ))
    long_running="$(runtime_group_value "$category" 5)"
    printf '| %s | %s | %s | %s | %s | %s | %s |\n' \
      "$label" "$count" "$(human_bytes_value "$rss")" \
      "$(runtime_group_value "$category" 6)" "$(runtime_group_value "$category" 7)" \
      "$long_running" "$(runtime_group_value "$category" 8)"
  done
  cat <<MARKDOWN

An orphan candidate means PPID 0/1 or a parent PID absent from the same snapshot. A long-running or high-count process is not automatically a leak. Renderer churn is evaluated only when two explicit runtime reports are compared. No process is stopped or cleaned up.
MARKDOWN
}

load_previous_report() {
  local previous_tool

  if [ "$COMPARE_REQUESTED" -ne 1 ]; then
    return
  fi

  if [ ! -r "$COMPARE_FILE" ]; then
    die "--compare file is not readable"
  fi

  if ! command -v jq >/dev/null 2>&1; then
    die "--compare requires jq to read a previous codex-healthkit JSON report"
  fi

  previous_tool="$(jq -r '.tool // empty' "$COMPARE_FILE" 2>/dev/null)" ||
    die "--compare expects a valid codex-healthkit JSON report"

  if [ "$previous_tool" != "codex-healthkit" ]; then
    die "--compare expects output from codex-healthkit check --json"
  fi

  PREVIOUS_GENERATED_AT="$(previous_string '.generated_at')"
  if [ -z "$PREVIOUS_GENERATED_AT" ]; then
    PREVIOUS_GENERATED_AT="unknown"
  fi

  PREV_LOG_WAL_BYTES="$(previous_number '.state.logs_2_sqlite_wal.bytes')"
  PREV_LOG_DB_BYTES="$(previous_number '.state.logs_2_sqlite.bytes')"
  PREV_SESSIONS_BYTES="$(previous_number '.state.sessions.bytes')"
  PREV_SESSIONS_COUNT="$(previous_number '.state.sessions.jsonl_count')"
  PREV_ARCHIVED_BYTES="$(previous_number '.state.archived_sessions.bytes')"
  PREV_ARCHIVED_COUNT="$(previous_number '.state.archived_sessions.jsonl_count')"
  PREV_QUARANTINE_BYTES="$(previous_number '.state.quarantine.bytes')"

  DELTA_LOG_WAL_BYTES=$((LOG_WAL_BYTES - PREV_LOG_WAL_BYTES))
  DELTA_LOG_DB_BYTES=$((LOG_DB_BYTES - PREV_LOG_DB_BYTES))
  DELTA_SESSIONS_BYTES=$((SESSIONS_BYTES - PREV_SESSIONS_BYTES))
  DELTA_SESSIONS_COUNT=$((SESSIONS_COUNT - PREV_SESSIONS_COUNT))
  DELTA_ARCHIVED_BYTES=$((ARCHIVED_BYTES - PREV_ARCHIVED_BYTES))
  DELTA_ARCHIVED_COUNT=$((ARCHIVED_COUNT - PREV_ARCHIVED_COUNT))
  DELTA_QUARANTINE_BYTES=$((QUARANTINE_BYTES - PREV_QUARANTINE_BYTES))

  load_runtime_comparison

  COMPARE_LOADED=1
  COMPARE_NOTE="explicit previous report loaded; comparison uses metadata already emitted by codex-healthkit and is informational"
}

run_codex_doctor() {
  local doctor_json doctor_exit doctor_summary
  doctor_exit=0

  if [ "$WITH_CODEX_DOCTOR" -ne 1 ]; then
    DOCTOR_REQUESTED=0
    DOCTOR_RAN=0
    DOCTOR_STATUS="skipped"
    DOCTOR_NOTE="not requested; pass --with-codex-doctor to run official Codex doctor"
    DOCTOR_OK=0
    DOCTOR_WARN=0
    DOCTOR_FAIL=0
    return
  fi

  DOCTOR_REQUESTED=1

  if ! command -v codex >/dev/null 2>&1; then
    DOCTOR_RAN=0
    DOCTOR_STATUS="unavailable"
    DOCTOR_NOTE="codex command not found"
    DOCTOR_OK=0
    DOCTOR_WARN=0
    DOCTOR_FAIL=0
    return
  fi

  if ! command -v jq >/dev/null 2>&1; then
    DOCTOR_RAN=0
    DOCTOR_STATUS="skipped"
    DOCTOR_NOTE="jq is required to extract redacted codex doctor JSON safely"
    DOCTOR_OK=0
    DOCTOR_WARN=0
    DOCTOR_FAIL=0
    return
  fi

  doctor_json="$(codex doctor --json 2>/dev/null)" || doctor_exit=$?
  if [ "$doctor_exit" -ne 0 ] && [ -z "$doctor_json" ]; then
    DOCTOR_RAN=0
    DOCTOR_STATUS="error"
    DOCTOR_NOTE="codex doctor --json exited with code $doctor_exit"
    DOCTOR_OK=0
    DOCTOR_WARN=0
    DOCTOR_FAIL=0
    return
  fi

  doctor_summary="$(
    printf '%s' "$doctor_json" |
      jq -r '[
        (.overallStatus // "unknown"),
        ([.checks[]? | select(.status == "ok")] | length),
        ([.checks[]? | select(.status == "warn" or .status == "warning" or .status == "degraded")] | length),
        ([.checks[]? | select(.status == "fail" or .status == "error")] | length)
      ] | @tsv' 2>/dev/null
  )" || {
    DOCTOR_RAN=0
    DOCTOR_STATUS="error"
    DOCTOR_NOTE="codex doctor --json did not return parseable JSON"
    DOCTOR_OK=0
    DOCTOR_WARN=0
    DOCTOR_FAIL=0
    return
  }

  DOCTOR_RAN=1
  IFS="$(printf '\t')" read -r DOCTOR_STATUS DOCTOR_OK DOCTOR_WARN DOCTOR_FAIL <<EOF
$doctor_summary
EOF
  DOCTOR_NOTE="redacted official Codex doctor JSON summarized; raw output not included"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    check)
      COMMAND="check"
      ;;
    --markdown)
      FORMAT="markdown"
      ;;
    --json)
      FORMAT="json"
      ;;
    --with-codex-version)
      WITH_CODEX_VERSION=1
      ;;
    --with-codex-doctor)
      WITH_CODEX_DOCTOR=1
      ;;
    --with-runtime)
      WITH_RUNTIME=1
      ;;
    --compare)
      shift
      [ "$#" -gt 0 ] || die "--compare requires a previous report path"
      COMPARE_FILE="$1"
      COMPARE_REQUESTED=1
      ;;
    --compare=*)
      COMPARE_FILE="${1#--compare=}"
      [ -n "$COMPARE_FILE" ] || die "--compare requires a previous report path"
      COMPARE_REQUESTED=1
      ;;
    --version)
      printf 'codex-healthkit %s\n' "$VERSION"
      exit 0
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
  shift
done

[ "$COMMAND" = "check" ] || die "unsupported command: $COMMAND"

GENERATED_AT="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
RUNTIME_PS_FILE="$(mktemp)"
RUNTIME_PRESSURE_FILE="$(mktemp)"
RUNTIME_SWAP_FILE="$(mktemp)"
RUNTIME_PIDS_FILE="$(mktemp)"
RUNTIME_TARGETS_FILE="$(mktemp)"
RUNTIME_PREVIOUS_IDS_FILE="$(mktemp)"
RUNTIME_CURRENT_IDS_FILE="$(mktemp)"
trap 'rm -f "$RUNTIME_PS_FILE" "$RUNTIME_PRESSURE_FILE" "$RUNTIME_SWAP_FILE" "$RUNTIME_PIDS_FILE" "$RUNTIME_TARGETS_FILE" "$RUNTIME_PREVIOUS_IDS_FILE" "$RUNTIME_CURRENT_IDS_FILE"' EXIT
CODEX_HOME_DIR="${CODEX_HOME:-$HOME/.codex}"
SQLITE_HOME_DIR="$(resolve_sqlite_home)"

SESSIONS_DIR="$CODEX_HOME_DIR/sessions"
ARCHIVED_DIR="$CODEX_HOME_DIR/archived_sessions"
QUARANTINE_DIR="$CODEX_HOME_DIR/quarantine"
LOG_DB="$SQLITE_HOME_DIR/logs_2.sqlite"
LOG_SHM="$SQLITE_HOME_DIR/logs_2.sqlite-shm"
LOG_WAL="$SQLITE_HOME_DIR/logs_2.sqlite-wal"

CODEX_FOUND=0
CODEX_VERSION="not requested"
if command -v codex >/dev/null 2>&1; then
  CODEX_FOUND=1
  if [ "$WITH_CODEX_VERSION" -eq 1 ]; then
    CODEX_VERSION="$(codex --version 2>/dev/null || printf 'unknown')"
  fi
fi

SESSIONS_EXISTS="$(path_exists_bool "$SESSIONS_DIR")"
ARCHIVED_EXISTS="$(path_exists_bool "$ARCHIVED_DIR")"
QUARANTINE_EXISTS="$(path_exists_bool "$QUARANTINE_DIR")"
LOG_DB_EXISTS="$(path_exists_bool "$LOG_DB")"
LOG_SHM_EXISTS="$(path_exists_bool "$LOG_SHM")"
LOG_WAL_EXISTS="$(path_exists_bool "$LOG_WAL")"

SESSIONS_SIZE="$(human_size_for "$SESSIONS_DIR")"
ARCHIVED_SIZE="$(human_size_for "$ARCHIVED_DIR")"
QUARANTINE_SIZE="$(human_size_for "$QUARANTINE_DIR")"
LOG_DB_SIZE="$(human_size_for "$LOG_DB")"
LOG_SHM_SIZE="$(human_size_for "$LOG_SHM")"
LOG_WAL_SIZE="$(human_size_for "$LOG_WAL")"

SESSIONS_BYTES="$(tree_bytes_for "$SESSIONS_DIR")"
ARCHIVED_BYTES="$(tree_bytes_for "$ARCHIVED_DIR")"
QUARANTINE_BYTES="$(tree_bytes_for "$QUARANTINE_DIR")"
LOG_DB_BYTES="$(bytes_for "$LOG_DB")"
LOG_SHM_BYTES="$(bytes_for "$LOG_SHM")"
LOG_WAL_BYTES="$(bytes_for "$LOG_WAL")"

SESSIONS_COUNT="$(count_jsonl_files "$SESSIONS_DIR")"
ARCHIVED_COUNT="$(count_jsonl_files "$ARCHIVED_DIR")"

OVERALL_STATUS="$(overall_status_for "$LOG_DB_BYTES" "$LOG_WAL_BYTES")"
SQLITE_NOTE="$(health_note "$LOG_DB_BYTES" "$LOG_WAL_BYTES")"

DOCTOR_REQUESTED=0
DOCTOR_RAN=0
DOCTOR_STATUS="skipped"
DOCTOR_NOTE=""
DOCTOR_OK=0
DOCTOR_WARN=0
DOCTOR_FAIL=0
run_codex_doctor

RUNTIME_REQUESTED=0
RUNTIME_SUPPORTED=0
RUNTIME_OS="not requested"
RUNTIME_STATUS="skipped"
RUNTIME_NOTE=""
RUNTIME_MEMORY_FREE_PERCENT=-1
RUNTIME_SWAP_USED_MIB=0
collect_runtime

if [ "$RUNTIME_STATUS" = "watch" ] && [ "$OVERALL_STATUS" = "ok" ]; then
  OVERALL_STATUS="watch"
fi

if [ "$DOCTOR_RAN" = "1" ]; then
  if [ "$DOCTOR_FAIL" -gt 0 ]; then
    OVERALL_STATUS="fail"
  elif [ "$DOCTOR_WARN" -gt 0 ] && [ "$OVERALL_STATUS" = "ok" ]; then
    OVERALL_STATUS="watch"
  fi
fi

PREVIOUS_GENERATED_AT=""
PREV_LOG_WAL_BYTES=0
PREV_LOG_DB_BYTES=0
PREV_SESSIONS_BYTES=0
PREV_SESSIONS_COUNT=0
PREV_ARCHIVED_BYTES=0
PREV_ARCHIVED_COUNT=0
PREV_QUARANTINE_BYTES=0
DELTA_LOG_WAL_BYTES=0
DELTA_LOG_DB_BYTES=0
DELTA_SESSIONS_BYTES=0
DELTA_SESSIONS_COUNT=0
DELTA_ARCHIVED_BYTES=0
DELTA_ARCHIVED_COUNT=0
DELTA_QUARANTINE_BYTES=0
RUNTIME_COMPARE_AVAILABLE=0
RUNTIME_COMPARE_NOTE="runtime comparison unavailable; collect both reports with --with-runtime on macOS"
RUNTIME_RENDERER_STARTED=0
RUNTIME_RENDERER_EXITED=0
RUNTIME_RENDERER_CHURN=0
COMPUTER_USE_CLIENT_GROWTH=0
PLAYWRIGHT_WORKER_GROWTH=0
PREV_COMPUTER_USE_CLIENT_COUNT=0
PREV_PLAYWRIGHT_WORKER_COUNT=0
CURRENT_COMPUTER_USE_CLIENT_COUNT="$(runtime_group_value computer_use_client 2)"
CURRENT_PLAYWRIGHT_WORKER_COUNT="$(runtime_group_value playwright_worker 2)"
DELTA_COMPUTER_USE_CLIENT_COUNT=0
DELTA_PLAYWRIGHT_WORKER_COUNT=0
load_previous_report

if [ "$FORMAT" = "json" ]; then
  cat <<JSON
{
  "tool": "codex-healthkit",
  "version": $(json_string "$VERSION"),
  "generated_at": $(json_string "$GENERATED_AT"),
  "summary": {
    "status": $(json_string "$OVERALL_STATUS"),
    "sqlite_note": $(json_string "$SQLITE_NOTE")
  },
  "codex_cli": {
    "found": $(bool_json "$CODEX_FOUND"),
    "version": $(json_string "$CODEX_VERSION")
  },
  "state": {
    "sessions": {
      "exists": $(bool_json "$SESSIONS_EXISTS"),
      "bytes": $SESSIONS_BYTES,
      "size": $(json_string "$SESSIONS_SIZE"),
      "jsonl_count": $SESSIONS_COUNT
    },
    "archived_sessions": {
      "exists": $(bool_json "$ARCHIVED_EXISTS"),
      "bytes": $ARCHIVED_BYTES,
      "size": $(json_string "$ARCHIVED_SIZE"),
      "jsonl_count": $ARCHIVED_COUNT
    },
    "quarantine": {
      "exists": $(bool_json "$QUARANTINE_EXISTS"),
      "bytes": $QUARANTINE_BYTES,
      "size": $(json_string "$QUARANTINE_SIZE")
    },
    "logs_2_sqlite": {
      "exists": $(bool_json "$LOG_DB_EXISTS"),
      "bytes": $LOG_DB_BYTES,
      "size": $(json_string "$LOG_DB_SIZE")
    },
    "logs_2_sqlite_shm": {
      "exists": $(bool_json "$LOG_SHM_EXISTS"),
      "bytes": $LOG_SHM_BYTES,
      "size": $(json_string "$LOG_SHM_SIZE")
    },
    "logs_2_sqlite_wal": {
      "exists": $(bool_json "$LOG_WAL_EXISTS"),
      "bytes": $LOG_WAL_BYTES,
      "size": $(json_string "$LOG_WAL_SIZE")
    }
  },
  "comparison": $(comparison_json),
  "runtime": $(runtime_json),
  "official_codex_doctor": {
    "requested": $(bool_json "$DOCTOR_REQUESTED"),
    "ran": $(bool_json "$DOCTOR_RAN"),
    "status": $(json_string "$DOCTOR_STATUS"),
    "ok": $DOCTOR_OK,
    "warn": $DOCTOR_WARN,
    "fail": $DOCTOR_FAIL,
    "note": $(json_string "$DOCTOR_NOTE")
  },
  "safety": {
    "auth_files_read": false,
    "token_files_read": false,
    "cookies_read": false,
    "sqlite_contents_read": false,
    "session_transcript_contents_read": false,
    "process_arguments_read": false,
    "process_environment_read": false,
    "process_open_files_read": false,
    "healthkit_network_telemetry": false
  }
}
JSON
  exit 0
fi

cat <<MARKDOWN
# codex-healthkit report

Generated: $GENERATED_AT

## Summary

- status: \`$OVERALL_STATUS\`
- sqlite_note: $SQLITE_NOTE
- default_mode: local file metadata only

## Codex CLI

- found: \`$(if [ "$CODEX_FOUND" = "1" ]; then printf 'yes'; else printf 'no'; fi)\`
- version: \`$(markdown_inline "$CODEX_VERSION")\`
- version_requested: \`$(if [ "$WITH_CODEX_VERSION" = "1" ]; then printf 'yes'; else printf 'no'; fi)\`

## Local State Metadata

| item | exists | bytes | size | count | note |
|---|---:|---:|---:|---:|---|
| active sessions | $(if [ "$SESSIONS_EXISTS" = "1" ]; then printf 'yes'; else printf 'no'; fi) | $SESSIONS_BYTES | $SESSIONS_SIZE | $SESSIONS_COUNT | file count only; transcript contents not read |
| archived sessions | $(if [ "$ARCHIVED_EXISTS" = "1" ]; then printf 'yes'; else printf 'no'; fi) | $ARCHIVED_BYTES | $ARCHIVED_SIZE | $ARCHIVED_COUNT | review before deleting |
| quarantine | $(if [ "$QUARANTINE_EXISTS" = "1" ]; then printf 'yes'; else printf 'no'; fi) | $QUARANTINE_BYTES | $QUARANTINE_SIZE | - | metadata only |
| logs_2.sqlite | $(if [ "$LOG_DB_EXISTS" = "1" ]; then printf 'yes'; else printf 'no'; fi) | $LOG_DB_BYTES | $LOG_DB_SIZE | - | size only; SQLite contents not read |
| logs_2.sqlite-shm | $(if [ "$LOG_SHM_EXISTS" = "1" ]; then printf 'yes'; else printf 'no'; fi) | $LOG_SHM_BYTES | $LOG_SHM_SIZE | - | size only |
| logs_2.sqlite-wal | $(if [ "$LOG_WAL_EXISTS" = "1" ]; then printf 'yes'; else printf 'no'; fi) | $LOG_WAL_BYTES | $LOG_WAL_SIZE | - | size only |
MARKDOWN

comparison_markdown

